## Line Chart

```svg
<!-- Grid -->
<line x1="100" y1="200" x2="1100" y2="200" stroke="var(--grid)" stroke-width="1" />
<line x1="100" y1="350" x2="1100" y2="350" stroke="var(--grid)" stroke-width="1" />
<line x1="100" y1="500" x2="1100" y2="500" stroke="var(--grid)" stroke-width="1" />
<line x1="100" y1="650" x2="1100" y2="650" stroke="var(--grid)" stroke-width="1" />

<!-- Line path -->
<polyline
  points="150,550 300,500 450,480 600,350 750,300 900,280 1050,200"
  fill="none"
  stroke="var(--accent)"
  stroke-width="3"
  stroke-linecap="round"
  stroke-linejoin="round"
/>

<!-- Area fill (optional, for emphasis) -->
<polygon
  points="150,550 300,500 450,480 600,350 750,300 900,280 1050,200 1050,650 150,650"
  fill="var(--accent)"
  opacity="0.1"
/>

<!-- Data points -->
<circle cx="150" cy="550" r="5" fill="var(--accent)" />
<circle cx="300" cy="500" r="5" fill="var(--accent)" />
<circle cx="450" cy="480" r="5" fill="var(--accent)" />
<circle cx="600" cy="350" r="5" fill="var(--accent)" />
<circle cx="750" cy="300" r="5" fill="var(--accent)" />
<circle cx="900" cy="280" r="5" fill="var(--accent)" />
<circle cx="1050" cy="200" r="5" fill="var(--accent)" />

<!-- X-axis labels -->
<text x="150" y="690" class="axis-label" text-anchor="middle">Jan</text>
<text x="300" y="690" class="axis-label" text-anchor="middle">Feb</text>
<!-- ... more months ... -->
```

